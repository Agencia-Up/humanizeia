# Copie este arquivo pra .env.local e preencha as keys que quiser usar.
# .env.local NÃO é commitado (.gitignore inclui *.local).
#
# Sem nenhuma key: REPL roda em modo MOCK (sem chamar LLM, gratis).
# Com OPENAI_API_KEY: REPL roda em modo LIVE chamando gpt-4o de verdade.

# OpenAI (modo LIVE do REPL chat:local)
# OPENAI_API_KEY=sk-proj-...

# Anthropic (sumarização hierárquica IT-3.2 — opcional pro REPL)
# ANTHROPIC_API_KEY=sk-ant-api03-...
